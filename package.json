{
  "name": "bit-cut-studio",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm --workspace apps/editor-web run build",
    "dev": "npm --workspace apps/editor-web run dev",
    "test": "npm --workspace packages/export run validate:fixtures",
    "test:exports": "npm --workspace packages/export run validate:fixtures",
    "test:interop": "npm --workspace packages/export run test:interop",
    "transcribe:install": "python3 -m pip install -r scripts/requirements.txt",
    "transcribe:extract": "bash scripts/extract-audio-wav.sh",
    "transcribe:whisper": "python3 scripts/transcribe_whisper.py",
    "transcribe:media": "bash scripts/run-whisper-transcription.sh",
    "media-api": "node apps/media-api/server.js"
  }
}
